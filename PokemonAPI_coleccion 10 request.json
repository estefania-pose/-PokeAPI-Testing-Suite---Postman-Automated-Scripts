{
  "info": {
    "name": "PokemonAPI",
    "_postman_id": "b3f1a2c4-5d6e-4f7a-8b9c-1d2e3f4a5b6c",
    "description": "Colección de pruebas de API sobre PokeAPI (https://pokeapi.co/api/v2/) - 10 pruebas (5 positivas / 5 negativas) para afianzar conocimientos de testing de backend y frontend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://pokeapi.co/api/v2/",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Obtener un Pokémon existente",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}pokemon/pikachu",
          "host": ["{{base_url}}pokemon"],
          "path": ["pikachu"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code es 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"El nombre es pikachu\", () => {",
              "    pm.expect(pm.response.json().name).to.eql(\"pikachu\");",
              "});",
              "pm.test(\"Tiene el campo 'abilities'\", () => {",
              "    pm.expect(pm.response.json()).to.have.property(\"abilities\");",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Obtener un Pokémon por ID numérico",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}pokemon/6",
          "host": ["{{base_url}}pokemon"],
          "path": ["6"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code es 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"El id coincide\", () => {",
              "    pm.expect(pm.response.json().id).to.eql(6);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Listado paginado de Pokémon",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}pokemon?limit=20&offset=0",
          "host": ["{{base_url}}pokemon"],
          "query": [
            { "key": "limit", "value": "20" },
            { "key": "offset", "value": "0" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code es 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Devuelve exactamente 20 resultados\", () => {",
              "    pm.expect(pm.response.json().results.length).to.eql(20);",
              "});",
              "pm.test(\"Tiene campo 'next' para paginar\", () => {",
              "    pm.expect(pm.response.json()).to.have.property(\"next\");",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Consultar un tipo de Pokémon",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}type/electric",
